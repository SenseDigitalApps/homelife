# Development defaults (safe for local use)
DJANGO_SECRET_KEY=change-me-with-a-strong-32-plus-char-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_HSTS_SECONDS=31536000

# Database
POSTGRES_DB=medsync
POSTGRES_USER=medsync
POSTGRES_PASSWORD=medsync_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
JWT_ACCESS_LIFETIME_MIN=30
JWT_REFRESH_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=false
JWT_BLACKLIST_AFTER_ROTATION=false
JWT_UPDATE_LAST_LOGIN=true

# IA (opcional)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Storage (opcional para PDFs en nube)
REPORTS_STORAGE=local

# Security cookies / trusted origins (used when DJANGO_DEBUG=false)
SECURE_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
CSRF_TRUSTED_ORIGINS=

# Production checklist (required before deploy)
# - Set DJANGO_DEBUG=false
# - Use a strong DJANGO_SECRET_KEY (32+ chars)
# - Set DJANGO_ALLOWED_HOSTS to your domain(s)
# - Set all POSTGRES_* values from managed DB credentials
# - Keep JWT_* and SECURE_HSTS_SECONDS reviewed per policy
# - For production, prefer JWT_ROTATE_REFRESH_TOKENS=true and JWT_BLACKLIST_AFTER_ROTATION=true
